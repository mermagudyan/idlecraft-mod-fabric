		"main": [
			"io.github.mermagudyan.idlecraft.IdleMod"
		],
		"client": [
			"io.github.mermagudyan.idlecraft.client.ModKeyBindings",
			"io.github.mermagudyan.idlecraft.client.network.ClientNetworkInit"
		]
	},
	"mixins": [
