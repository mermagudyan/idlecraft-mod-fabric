{
	"schemaVersion": 1,
	"id": "idlecraft",
	"version": "${version}",
	"name": "Idlecraft",
	"description": "Idle mod for minecraft. LOL",
	"authors": [
		"mermagudyan"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/mermagudyan/idlecraft-mod-fabric"
	},
	"license": "MIT",
	"icon": "assets/idlecraft/icon.png",
	"environment": "*",
